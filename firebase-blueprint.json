{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "A luxury real estate listing",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The name of the property"
        },
        "price": {
          "type": "string",
          "description": "The price of the property (formatted string)"
        },
        "location": {
          "type": "string",
          "description": "The geographic location"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the property image"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the property"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the listing was created"
        },
        "authorUid": {
          "type": "string",
          "description": "UID of the user who created the listing"
        }
      },
      "required": [
        "title",
        "price",
        "location",
        "imageUrl",
        "description"
      ]
    }
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of luxury property listings"
    }
  }
}
