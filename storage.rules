rules_version = '2';

// ☁️ Cloud Storage for Firebase
service firebase.storage {
  match /b/{bucket}/o {
    // 🏠 Properties: Only authenticated users can upload property images
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default rule to allow read/write for auth users otherwise
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
